---
interface Props {
  label: string;
  lat: number;
  lng: number;
  marker?: string;
  columns?: number;
  rows?: number;
  fontSize?: number;
  initialPhi?: number;
  initialTheta?: number;
}

const {
  label,
  lat,
  lng,
  marker = "@",
  columns = 40,
  rows = 18,
  fontSize = 10,
  initialPhi = -2.259,
  initialTheta = 0.485,
} = Astro.props;

const placeholder = [
  "                ########",
  "           #####.#####.######",
  "        ###...##...#...#.##.####",
  "      ###.......#####.#.##########",
  "     ##......##..#.##########..####",
  "    ##.....@####################..##",
  "    #.....##.#....####.#..##.#####.##",
  "   ##..#####.#.###.#########..#..##.#",
  "   ##.......#######.#####...###..#..#",
  "   ##..######.#.#.######.....#....###",
  "    ##....#.##.########............#",
  "     ##......########.............#",
  "      ##.....#######..#.........##",
  "        ###...#####...#......###",
  "          #####..........#####",
  "               ##########",
];

const placeholderHtml = placeholder
  .map((line) =>
    line
      .replaceAll(
        ".",
        '<span class="text-[#3b82f6]" data-theme-scramble-target>.</span>',
      )
      .replaceAll("@", '<span class="text-accent">@</span>'),
  )
  .join("\n");
---

<ascii-globe
  class="relative hidden cursor-grab self-start justify-self-end overflow-hidden text-muted-foreground select-none active:cursor-grabbing lg:block"
  data-label={label}
  data-lat={String(lat)}
  data-lng={String(lng)}
  data-marker={marker}
  data-columns={String(columns)}
  data-rows={String(rows)}
  data-initial-phi={String(initialPhi)}
  data-initial-theta={String(initialTheta)}
  role="img"
  aria-label={`ascii globe marking ${label}`}
  style={`font-size: ${fontSize}px; width: calc(${columns} * 0.6em); height: calc(${rows} * 1.32em); --globe-water: #3b82f6; --placeholder-offset: 1.1em; --placeholder-letter-spacing: -0.005em`}
>
  <canvas class="absolute size-px opacity-0" aria-hidden="true" data-source
  ></canvas>
  <canvas
    class="absolute inset-0 z-10 block max-w-full bg-background transition-opacity duration-200 ease-out"
    style="opacity: 0"
    data-canvas></canvas>
  <pre
    class="absolute inset-0 z-0 m-0 font-mono text-[1em] leading-[1.32] font-normal tracking-[var(--placeholder-letter-spacing)] text-muted-foreground transition-opacity duration-200 ease-out"
    style="transform: translateY(var(--placeholder-offset))"
    aria-hidden="true"
    data-placeholder
    data-theme-scramble-scope
    set:html={placeholderHtml}
  />
  <div
    class="pointer-events-none absolute inset-x-0 bottom-0 z-20 bg-background/75 text-center font-mono text-[10px] tracking-wide text-accent opacity-0 transition-opacity duration-200"
    data-hint
    aria-hidden="true"
  >
  </div>
</ascii-globe>

<script>
  import { prepareWithSegments } from "@chenglou/pretext";
  import createGlobe, { type COBEOptions, type Globe } from "cobe";

  const rgb = (
    red: number,
    green: number,
    blue: number,
  ): [number, number, number] => [red, green, blue];

  class AsciiGlobe extends HTMLElement {
    private canvas?: HTMLCanvasElement;
    private source?: HTMLCanvasElement;
    private placeholder?: HTMLElement;
    private placeholderText = "";
    private canSyncPlaceholder = false;
    private liveCanvasVisible = false;
    private sampleCanvas = document.createElement("canvas");
    private sampleContext = this.sampleCanvas.getContext("2d", {
      willReadFrequently: true,
    });
    private globe?: Globe;
    private animation = 0;
    private dragging = false;
    private pointerX = 0;
    private pointerY = 0;
    private phi = 0;
    private theta = 0.485;
    private hovered = false;
    private themeTransitionRunning = false;
    private lastFrame = 0;
    private readonly autoRotateRadiansPerSecond = 0.15;
    private readonly sourceSize = 220;
    private hint?: HTMLElement;
    private clickTimes: number[] = [];
    private hasDragged = false;
    private downX = 0;
    private downY = 0;
    private resetTimer = 0;
    private readonly secretWindow = 8000;
    private readonly secretTarget = 10;
    private readonly secretHints: Record<number, string> = {
      4: "[signal détecté]",
      5: "[orbite instable]",
      6: "[étoiles alignées]",
      7: "[carte du parcours trouvée]",
      8: "[ouverture du ciel]",
      9: "[dernier clic]",
    };
    connectedCallback() {
      this.canvas = this.querySelector("[data-canvas]") ?? undefined;
      this.source = this.querySelector("[data-source]") ?? undefined;
      this.placeholder = this.querySelector("[data-placeholder]") ?? undefined;
      this.hint = this.querySelector("[data-hint]") ?? undefined;
      this.placeholderText = this.placeholder?.textContent ?? "";
      this.phi = this.initialPhi;
      this.theta = this.initialTheta;
      this.syncPositionAttributes();

      this.addEventListener("pointerenter", this.onPointerEnter);
      this.addEventListener("pointerleave", this.onPointerLeave);
      this.addEventListener("pointerdown", this.onPointerDown);
      window.addEventListener("pointermove", this.onPointerMove);
      window.addEventListener("pointerup", this.onPointerUp);
      window.addEventListener("theme-transition:start", this.onThemeStart);
      window.addEventListener("theme-transition:end", this.onThemeEnd);

      this.init();
    }

    disconnectedCallback() {
      cancelAnimationFrame(this.animation);
      window.clearTimeout(this.resetTimer);
      this.globe?.destroy();
      this.removeEventListener("pointerenter", this.onPointerEnter);
      this.removeEventListener("pointerleave", this.onPointerLeave);
      this.removeEventListener("pointerdown", this.onPointerDown);
      window.removeEventListener("pointermove", this.onPointerMove);
      window.removeEventListener("pointerup", this.onPointerUp);
      window.removeEventListener("theme-transition:start", this.onThemeStart);
      window.removeEventListener("theme-transition:end", this.onThemeEnd);
    }

    private async init() {
      if (!this.source) return;

      try {
        await document.fonts?.ready;
      } catch {
        // keep rendering with fallback font
      }

      this.sampleCanvas.width = this.sourceSize;
      this.sampleCanvas.height = this.sourceSize;

      this.globe = createGlobe(this.source, this.options());
      this.animation = requestAnimationFrame(this.tick);
    }

    private options(): COBEOptions {
      return {
        width: this.sourceSize,
        height: this.sourceSize,
        devicePixelRatio: 1,
        phi: this.phi,
        theta: this.theta,
        diffuse: 1.35,
        mapSamples: 40000,
        mapBaseBrightness: 0,
        mapBrightness: 8,
        markerElevation: 0.1,
        markers: [
          {
            location: [this.lat, this.lng],
            size: 0.055,
          },
        ],
        baseColor: rgb(0.18, 0.18, 0.17),
        markerColor: rgb(1, 0.08, 0),
        glowColor: rgb(0, 0, 0),
        dark: 0,
        opacity: 1,
        scale: 1,
      };
    }

    private tick = (now: number) => {
      if (!this.globe || !this.source) return;

      const elapsed = this.lastFrame ? (now - this.lastFrame) / 1000 : 0;
      this.lastFrame = now;

      if (!this.autoRotationPaused) {
        this.phi += elapsed * this.autoRotateRadiansPerSecond;
        this.syncPositionAttributes();
      }

      this.globe.update({
        phi: this.phi,
        theta: this.theta,
      });
      this.drawAscii();

      this.animation = requestAnimationFrame(this.tick);
    };

    private drawAscii() {
      if (!this.canvas || !this.source || !this.sampleContext) {
        return;
      }

      this.sampleContext.clearRect(0, 0, this.sourceSize, this.sourceSize);
      this.sampleContext.drawImage(
        this.source,
        0,
        0,
        this.sourceSize,
        this.sourceSize,
      );
      const pixels = this.sampleContext.getImageData(
        0,
        0,
        this.sourceSize,
        this.sourceSize,
      );

      const lines = this.toAscii(pixels);
      if (this.canSyncPlaceholder) this.syncPlaceholder(lines);
      this.drawLines(lines, this.canvas);

      if (!this.liveCanvasVisible) {
        this.liveCanvasVisible = true;
        requestAnimationFrame(() => {
          if (this.canvas) this.canvas.style.opacity = "1";
        });
        window.setTimeout(() => {
          this.style.setProperty("--placeholder-offset", "-0.225em");
          if (this.placeholder) this.placeholder.style.opacity = "0";
          this.canSyncPlaceholder = true;
          this.syncPlaceholder(lines);
        }, 220);
      }
    }

    private syncPlaceholder(lines: string[]) {
      if (!this.placeholder) return;

      const text = lines.join("\n");
      if (text === this.placeholderText) return;

      this.placeholderText = text;
      this.placeholder.innerHTML = lines
        .map((line) =>
          line
            .replaceAll(
              ".",
              '<span class="text-[#3b82f6]" data-theme-scramble-target>.</span>',
            )
            .replaceAll(
              this.marker,
              `<span class="text-accent">${this.marker}</span>`,
            ),
        )
        .join("\n");
    }

    private drawLines(lines: string[], canvas = this.canvas) {
      if (!canvas) return;

      const context = canvas.getContext("2d");
      if (!context) return;

      const computed = getComputedStyle(this.placeholder ?? this);
      const fontSize = Number.parseFloat(computed.fontSize) || 12;
      const lineHeight = fontSize * 1.32;
      const font = `${computed.fontWeight || "400"} ${fontSize}px ${computed.fontFamily}`;

      context.font = font;
      const characterWidth = context.measureText("0").width || fontSize * 0.6;
      const letterSpacing = Number.parseFloat(computed.letterSpacing) || 0;
      const cssWidth = Math.ceil(
        characterWidth * this.columns +
          letterSpacing * Math.max(0, this.columns - 1),
      );
      const cssHeight = Math.ceil(lineHeight * lines.length);
      const ratio = Math.min(window.devicePixelRatio || 1, 2);

      canvas.width = Math.ceil(cssWidth * ratio);
      canvas.height = Math.ceil(cssHeight * ratio);
      canvas.style.width = `${cssWidth}px`;
      canvas.style.height = `${cssHeight}px`;

      context.setTransform(ratio, 0, 0, ratio, 0, 0);
      context.clearRect(0, 0, cssWidth, cssHeight);
      context.font = font;
      context.textBaseline = "top";
      const landColor = computed.color;
      const waterColor =
        computed.getPropertyValue("--globe-water").trim() || landColor;
      const markerColor =
        getComputedStyle(document.documentElement)
          .getPropertyValue("--accent")
          .trim() || landColor;
      lines.forEach((line, index) => {
        prepareWithSegments(line, font);
        const y = index * lineHeight;

        for (const [charIndex, character] of [...line].entries()) {
          if (character === " ") continue;

          const x =
            context.measureText(line.slice(0, charIndex)).width +
            letterSpacing * charIndex;
          context.fillStyle =
            character === this.marker
              ? markerColor
              : character === "."
                ? waterColor
                : landColor;
          context.fillText(character, x, y);
        }
      });
    }

    private toAscii(pixels: ImageData) {
      const output: string[][] = [];
      let markerCandidate:
        | { row: number; column: number; score: number }
        | undefined;
      const cellWidth = this.sourceSize / this.columns;
      const cellHeight = this.sourceSize / this.rows;
      const water = ".";
      const land = "#";

      for (let row = 0; row < this.rows; row++) {
        const line: string[] = [];
        for (let column = 0; column < this.columns; column++) {
          let red = 0;
          let green = 0;
          let blue = 0;
          let alpha = 0;
          let samples = 0;
          let globeSamples = 0;
          let landSamples = 0;
          let markerSamples = 0;

          const startX = Math.floor(column * cellWidth);
          const endX = Math.floor((column + 1) * cellWidth);
          const startY = Math.floor(row * cellHeight);
          const endY = Math.floor((row + 1) * cellHeight);

          for (let y = startY; y < endY; y += 2) {
            for (let x = startX; x < endX; x += 2) {
              const index = (y * pixels.width + x) * 4;
              red += pixels.data[index] ?? 0;
              green += pixels.data[index + 1] ?? 0;
              blue += pixels.data[index + 2] ?? 0;
              alpha += pixels.data[index + 3] ?? 0;
              const pixelAlpha = pixels.data[index + 3] ?? 0;
              const pixelRed = pixels.data[index] ?? 0;
              const pixelGreen = pixels.data[index + 1] ?? 0;
              const pixelBlue = pixels.data[index + 2] ?? 0;
              const pixelLuminance = (pixelRed + pixelGreen + pixelBlue) / 3;

              if (pixelAlpha > 8) globeSamples++;
              if (
                pixelAlpha > 8 &&
                pixelRed - Math.max(pixelGreen, pixelBlue) > 32 &&
                pixelRed > 78
              ) {
                markerSamples++;
              }
              if (pixelAlpha > 8 && pixelLuminance < 18) landSamples++;
              samples++;
            }
          }

          red /= samples;
          green /= samples;
          blue /= samples;
          alpha /= samples;

          if (globeSamples / samples < 0.08 || alpha < 8) {
            line.push(" ");
            continue;
          }

          const markerScore = markerSamples / Math.max(1, globeSamples);
          if (
            markerScore > 0.015 &&
            (!markerCandidate || markerScore > markerCandidate.score)
          ) {
            markerCandidate = { row, column, score: markerScore };
          }

          line.push(
            landSamples / Math.max(1, globeSamples) > 0.09 ? land : water,
          );
        }
        output.push(line);
      }

      if (markerCandidate) {
        output[markerCandidate.row]![markerCandidate.column] = this.marker;
      }

      return output.map((line) => line.join("").trimEnd());
    }

    private get autoRotationPaused() {
      return this.hovered || this.dragging || this.themeTransitionRunning;
    }

    private onPointerEnter = () => {
      this.hovered = true;
    };

    private onPointerLeave = () => {
      this.hovered = false;
    };

    private onThemeStart = () => {
      this.themeTransitionRunning = true;
    };

    private onThemeEnd = () => {
      this.themeTransitionRunning = false;
      this.lastFrame = performance.now();
    };

    private onPointerDown = (event: PointerEvent) => {
      this.dragging = true;
      this.hasDragged = false;
      this.downX = event.clientX;
      this.downY = event.clientY;
      this.pointerX = event.clientX;
      this.pointerY = event.clientY;
      this.setPointerCapture(event.pointerId);
    };

    private onPointerMove = (event: PointerEvent) => {
      if (!this.dragging) return;
      if (
        Math.hypot(event.clientX - this.downX, event.clientY - this.downY) > 6
      ) {
        this.hasDragged = true;
      }
      this.phi += (event.clientX - this.pointerX) * 0.01;
      this.theta = Math.max(
        -Math.PI / 2,
        Math.min(
          Math.PI / 2,
          this.theta + (event.clientY - this.pointerY) * 0.008,
        ),
      );
      this.pointerX = event.clientX;
      this.pointerY = event.clientY;
      this.syncPositionAttributes();
    };

    private onPointerUp = () => {
      if (this.dragging && !this.hasDragged) this.registerSecretClick();
      this.dragging = false;
      this.syncPositionAttributes();
    };

    private registerSecretClick() {
      const now = performance.now();
      this.clickTimes.push(now);
      this.clickTimes = this.clickTimes.filter(
        (time) => now - time <= this.secretWindow,
      );
      const count = this.clickTimes.length;
      window.clearTimeout(this.resetTimer);

      if (count >= this.secretTarget) {
        this.clickTimes = [];
        this.setHint("");
        window.dispatchEvent(
          new CustomEvent("globe:secret-unlock", { bubbles: true }),
        );
        return;
      }

      const label = this.secretHints[count];
      this.setHint(label ? `${label} ${this.secretTarget - count} more` : "");
      this.resetTimer = window.setTimeout(() => {
        this.clickTimes = [];
        this.setHint("");
      }, this.secretWindow);
    }

    private setHint(text: string) {
      if (!this.hint) return;
      if (text) {
        this.hint.textContent = text;
        this.hint.style.opacity = "1";
      } else {
        this.hint.style.opacity = "0";
      }
    }

    private syncPositionAttributes() {
      this.dataset.currentPhi = String(this.phi);
      this.dataset.currentTheta = String(this.theta);
    }

    private get lat() {
      return Number(this.dataset.lat ?? 0);
    }

    private get lng() {
      return Number(this.dataset.lng ?? 0);
    }

    private get marker() {
      return this.dataset.marker ?? "@";
    }

    private get columns() {
      return Number(this.dataset.columns ?? 40);
    }

    private get rows() {
      return Number(this.dataset.rows ?? 18);
    }

    private get initialPhi() {
      return Number(
        this.dataset.currentPhi ?? this.dataset.initialPhi ?? -2.259,
      );
    }

    private get initialTheta() {
      return Number(
        this.dataset.currentTheta ?? this.dataset.initialTheta ?? 0.485,
      );
    }
  }

  if (!customElements.get("ascii-globe")) {
    customElements.define("ascii-globe", AsciiGlobe);
  }
</script>
