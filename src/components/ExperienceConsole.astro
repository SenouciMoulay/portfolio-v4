---
import { getLocaleData, localeFromPath, type USER } from "../consts";

interface Props {
  experiences: typeof USER.experiences.entries;
}

const { experiences } = Astro.props;
const locale = localeFromPath(Astro.url.pathname);
const { labels } = getLocaleData(locale);

const monthFormatter = new Intl.DateTimeFormat(
  locale === "en" ? "en-US" : "fr-FR",
  {
    month: "short",
    year: "numeric",
  },
);

const formatDate = (date: Date) => monthFormatter.format(date).toLowerCase();
const formatRange = (experience: (typeof experiences)[number]) =>
  `${formatDate(experience.startDate)} — ${
    experience.endDate ? formatDate(experience.endDate) : labels.present
  }`;
---

<experience-console class="block">
  <ul>
    {
      experiences.map((experience, index) => (
        <li
          class="border-b border-dashed border-border/70 last:border-0"
          data-row
          data-index={String(index)}
        >
          <button
            type="button"
            class="group flex w-full items-baseline gap-2 bg-transparent py-3 text-left outline-none"
            aria-expanded={index === 0 ? "true" : "false"}
            data-trigger
            data-initial-keyboard-focus={index === 0 ? true : undefined}
          >
            <span
              aria-hidden="true"
              class:list={[
                "inline-block w-[0.6em]",
                index === 0 ? "animate-blink text-accent" : "text-transparent",
              ]}
              data-cursor
            >
              █
            </span>
            <span
              class="w-5 shrink-0 text-xs text-muted-foreground"
              data-toggle
            >
              {index === 0 ? "[-]" : "[+]"}
            </span>
            <span class="flex-1">
              <span
                class:list={[
                  "font-medium transition-colors group-hover:text-accent",
                  index === 0 ? "text-accent" : "text-foreground",
                ]}
                data-title
              >
                {experience.title.toLowerCase()}
              </span>
              <span class="text-muted-foreground">
                {" "}
                @ {experience.company.name?.toLowerCase() ?? labels.independent}
              </span>
            </span>
            <span class="hidden shrink-0 text-xs text-muted-foreground sm:inline">
              {formatRange(experience)}
            </span>
          </button>

          <div
            class="grid grid-cols-[1.7rem_1fr] gap-x-1 pb-5 pl-1 text-sm"
            data-panel
            hidden={index !== 0}
          >
            <div aria-hidden="true" class="text-border">
              └
            </div>
            <div>
              <p class="mb-3 text-xs text-muted-foreground sm:hidden">
                {formatRange(experience)} ·{" "}
                {experience.company.location.toLowerCase()}
              </p>
              <p class="mb-3 hidden text-xs text-muted-foreground sm:block">
                {experience.company.location.toLowerCase()}
              </p>
              <ul class="space-y-2 leading-relaxed text-foreground/90">
                {experience.bulletpoints.map((bulletpoint) => (
                  <li class="flex gap-2">
                    <span class="text-accent select-none">›</span>
                    <span class="text-pretty">{bulletpoint}</span>
                  </li>
                ))}
              </ul>
              {experience.technologies && (
                <p class="mt-3 flex flex-wrap gap-x-3 gap-y-1 text-xs text-muted-foreground">
                  {experience.technologies.map((technology) => (
                    <span>
                      <span class="text-border">#</span>
                      {technology.replace("githubactions", "github-actions")}
                    </span>
                  ))}
                </p>
              )}
            </div>
          </div>
        </li>
      ))
    }
  </ul>
</experience-console>

<div class="print-only print-experience-list">
  {
    experiences.map((experience) => (
      <article class="print-experience">
        <header>
          <h3>
            {experience.title.toLowerCase()} @{" "}
            {experience.company.name?.toLowerCase() ?? labels.independent}
          </h3>
          <span>{formatRange(experience)}</span>
        </header>
        <p>{experience.company.location.toLowerCase()}</p>
        <ul>
          {experience.bulletpoints.map((bulletpoint) => (
            <li>{bulletpoint}</li>
          ))}
        </ul>
        {experience.technologies && (
          <p class="print-tech">
            {experience.technologies
              .map(
                (technology) =>
                  `#${technology.replace("githubactions", "github-actions")}`,
              )
              .join("  ")}
          </p>
        )}
      </article>
    ))
  }
</div>

<script>
  class ExperienceConsole extends HTMLElement {
    private selected = 0;
    private navActive = true;

    connectedCallback() {
      this.rows.forEach((row, index) => {
        const trigger = row.querySelector<HTMLButtonElement>("[data-trigger]");
        trigger?.addEventListener("click", () => {
          this.navActive = true;
          this.selected = index;
          this.toggle(index);
          this.sync();
        });
        trigger?.addEventListener("mouseenter", () => {
          this.navActive = true;
          this.selected = index;
          this.sync();
        });
        trigger?.addEventListener("focus", () => {
          this.navActive = true;
          this.selected = index;
          this.sync();
        });
      });

      this.addEventListener("focusout", this.onFocusOut);
      this.addEventListener("mouseleave", this.onMouseLeave);
      this.sync();
    }

    disconnectedCallback() {
      this.removeEventListener("focusout", this.onFocusOut);
      this.removeEventListener("mouseleave", this.onMouseLeave);
    }

    private get rows() {
      return Array.from(this.querySelectorAll<HTMLElement>("[data-row]"));
    }

    private toggle(index: number) {
      const row = this.rows[index];
      const trigger = row?.querySelector<HTMLButtonElement>("[data-trigger]");
      const panel = row?.querySelector<HTMLElement>("[data-panel]");
      if (!trigger || !panel) return;

      const isOpen = trigger.getAttribute("aria-expanded") === "true";
      trigger.setAttribute("aria-expanded", String(!isOpen));
      panel.hidden = isOpen;
    }

    private onFocusOut = (event: FocusEvent) => {
      if (
        event.relatedTarget instanceof Node &&
        this.contains(event.relatedTarget)
      ) {
        return;
      }

      this.navActive = false;
      this.sync();
    };

    private onMouseLeave = () => {
      if (!this.contains(document.activeElement)) {
        this.navActive = false;
        this.sync();
      }
    };

    private sync() {
      this.rows.forEach((row, index) => {
        const active = this.navActive && index === this.selected;
        const trigger = row.querySelector<HTMLButtonElement>("[data-trigger]");
        const cursor = row.querySelector<HTMLElement>("[data-cursor]");
        const title = row.querySelector<HTMLElement>("[data-title]");
        const toggle = row.querySelector<HTMLElement>("[data-toggle]");
        const panel = row.querySelector<HTMLElement>("[data-panel]");
        const isOpen = trigger?.getAttribute("aria-expanded") === "true";

        cursor?.classList.toggle("text-accent", active);
        cursor?.classList.toggle("text-transparent", !active);
        cursor?.classList.toggle("animate-blink", active);
        title?.classList.toggle("text-accent", active);
        title?.classList.toggle("text-foreground", !active);
        if (toggle) toggle.textContent = isOpen ? "[-]" : "[+]";
        if (panel) panel.hidden = !isOpen;
      });
    }
  }

  if (!customElements.get("experience-console")) {
    customElements.define("experience-console", ExperienceConsole);
  }
</script>
