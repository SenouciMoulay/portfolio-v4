---
import { getLocaleData, localeFromPath } from "../consts";
import ScrambleLink from "./ScrambleLink.astro";

const locale = localeFromPath(Astro.url.pathname);
const { config: CONFIG, user: USER } = getLocaleData(locale);
const year = new Date().getFullYear();
const email = USER.socials.find((social) => social.label === "mail")?.href;
---

<footer
  class="site-footer mx-auto max-w-3xl px-5 pt-6 pb-10 text-xs text-muted-foreground"
>
  <div class="border-t border-border pt-6">
    <p>
      <span class="text-accent">$</span>{" "}
      {CONFIG.ui.footerCommand} —{" "}
      {
        email && (
          <ScrambleLink
            href={email}
            label={email.replace("mailto:", "")}
            external={false}
          />
        )
      }
    </p>
    <p class="mt-2">© {year}{" "}{USER.name.toLowerCase()}</p>
  </div>
</footer>
