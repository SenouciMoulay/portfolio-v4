---
import { localeFromPath } from "../consts";

interface Props {
  date: Date;
}

const { date } = Astro.props;
const locale = localeFromPath(Astro.url.pathname);
---

<time datetime={date.toISOString()}>
  {
    date.toLocaleDateString(locale === "en" ? "en-US" : "fr-FR", {
      year: "numeric",
      month: "short",
      day: "numeric",
    })
  }
</time>
