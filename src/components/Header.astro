---
import { getLocaleData, localeFromPath } from "../consts";
import ScrambleLink from "./ScrambleLink.astro";
import ThemeSwitcher from "./ThemeSwitcher.astro";

const pathname = Astro.url.pathname;
const locale = localeFromPath(pathname);
const { config: CONFIG, labels } = getLocaleData(locale);
const withoutLocale = pathname.replace(/^\/en(?=\/|$)/, "") || "/";
const homeHref = locale === "en" ? "/en/" : "/";
const alternateHref =
  locale === "en"
    ? withoutLocale
    : pathname === "/"
      ? "/en/"
      : `/en${pathname}`;
const alternateLabel = locale === "en" ? "fr" : "en";
---

<header
  class="site-header sticky top-0 z-50 border-b border-border bg-background/90 backdrop-blur"
>
  <nav
    class="mx-auto flex max-w-3xl items-center justify-between px-5 py-2 text-xs text-muted-foreground"
    aria-label={labels.primaryNavigation}
  >
    <ScrambleLink
      href={homeHref}
      label={`~/${CONFIG.meta.siteLabel}`}
      external={false}
    />
    <div class="flex items-center gap-4">
      <span class="hidden sm:inline">
        <span class="text-foreground">{CONFIG.ui.keyboardHint.move}</span>{" "}
        {CONFIG.ui.keyboardHint.moveLabel} ·{" "}
        <span class="text-foreground">{CONFIG.ui.keyboardHint.action}</span>{
          " "
        }
        {CONFIG.ui.keyboardHint.actionLabel} ·{" "}
        <span class="text-foreground">{CONFIG.ui.keyboardHint.theme}</span>{" "}
        {CONFIG.ui.keyboardHint.themeLabel}
      </span>
      <ThemeSwitcher />
      <ScrambleLink
        href={alternateHref}
        label={alternateLabel}
        external={false}
      />
    </div>
  </nav>
</header>
