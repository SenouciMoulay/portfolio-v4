---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<keyboard-navigator class:list={["block", className]}>
  <slot />
</keyboard-navigator>

<script>
  class KeyboardNavigator extends HTMLElement {
    private readonly selector =
      'a[href], button:not([disabled]), textarea:not([disabled]), input:not([disabled]), select:not([disabled]), [tabindex]:not([tabindex="-1"])';

    connectedCallback() {
      window.addEventListener("keydown", this.onKeyDown);
      requestAnimationFrame(() => {
        const initial =
          this.querySelector<HTMLElement>("[data-initial-keyboard-focus]") ??
          this.items[0];

        if (initial && document.activeElement === document.body) {
          initial.focus({ preventScroll: true });
        }
      });
    }

    disconnectedCallback() {
      window.removeEventListener("keydown", this.onKeyDown);
    }

    private get items() {
      return Array.from(
        this.querySelectorAll<HTMLElement>(this.selector),
      ).filter(
        (element) =>
          !element.hidden &&
          element.getAttribute("aria-hidden") !== "true" &&
          element.offsetParent !== null,
      );
    }

    private onKeyDown = (event: KeyboardEvent) => {
      if (this.isTyping(event.target)) return;

      const items = this.items;
      if (!items.length) return;

      const active = document.activeElement;
      const currentIndex =
        active instanceof HTMLElement ? items.indexOf(active) : -1;
      const initialIndex = items.findIndex((item) =>
        item.hasAttribute("data-initial-keyboard-focus"),
      );
      const fallbackIndex = initialIndex >= 0 ? initialIndex : 0;

      let nextIndex: number | undefined;
      if (event.key === "ArrowDown" || event.key === "j") {
        nextIndex =
          currentIndex < 0
            ? fallbackIndex
            : Math.min(items.length - 1, currentIndex + 1);
      } else if (event.key === "ArrowUp" || event.key === "k") {
        nextIndex =
          currentIndex < 0 ? fallbackIndex : Math.max(0, currentIndex - 1);
      } else if (event.key === "g") {
        nextIndex = 0;
      } else if (event.key === "G") {
        nextIndex = items.length - 1;
      }

      if (nextIndex === undefined) return;

      event.preventDefault();
      items[nextIndex]?.focus();
      items[nextIndex]?.scrollIntoView({
        block: "nearest",
        behavior: window.matchMedia("(prefers-reduced-motion: reduce)").matches
          ? "auto"
          : "smooth",
      });
    };

    private isTyping(target: EventTarget | null) {
      return (
        target instanceof HTMLElement &&
        (target.tagName === "INPUT" ||
          target.tagName === "TEXTAREA" ||
          target.tagName === "SELECT" ||
          target.isContentEditable)
      );
    }
  }

  if (!customElements.get("keyboard-navigator")) {
    customElements.define("keyboard-navigator", KeyboardNavigator);
  }
</script>
