---
import { getLocaleData, localeFromPath } from "../consts";

const locale = localeFromPath(Astro.url.pathname);
const { labels } = getLocaleData(locale);
---

<theme-switcher
  class="inline-flex"
  data-light-label={labels.theme.light}
  data-dark-label={labels.theme.dark}
>
  <button
    type="button"
    class="bg-transparent p-0 text-foreground underline decoration-border decoration-dotted underline-offset-4 outline-none hover:text-accent hover:decoration-accent focus-visible:text-accent focus-visible:decoration-accent"
    aria-label={labels.theme.aria}
    data-theme-toggle
  >
    {labels.theme.prefix}:<span data-theme-label>{labels.theme.light}</span>
  </button>
</theme-switcher>

<script>
  const GLYPHS = "!<>-_\\/[]{}=+*^?#0123456789";
  const REVEAL_DURATION_MS = 420;
  const SCRAMBLE_DURATION_MS = 260;
  const THEME_TRANSITION_BASE_IGNORED_SELECTOR = [
    "script",
    "style",
    "noscript",
    "svg",
    "canvas",
    ".sr-only",
    "[hidden]",
    "[data-fallback]",
    ".theme-sweep",
    ".theme-scramble-layer",
  ].join(",");
  const THEME_TRANSITION_STATIC_SELECTOR = [
    "[data-theme-transition-static]",
    "[data-theme-transition-rich-static] :is(img, picture, video, iframe, pre, code, figure[data-rehype-pretty-code-figure], .astro-code)",
  ].join(",");

  class ThemeSwitcher extends HTMLElement {
    private static transitionRunning = false;

    private button?: HTMLButtonElement;
    private label?: HTMLElement;
    private readonly storageKey = "theme";

    connectedCallback() {
      this.button = this.querySelector("[data-theme-toggle]") ?? undefined;
      this.label = this.querySelector("[data-theme-label]") ?? undefined;

      this.syncLabel();
      this.button?.addEventListener("click", this.toggle);
      window.addEventListener("keydown", this.onKeyDown);
    }

    disconnectedCallback() {
      this.button?.removeEventListener("click", this.toggle);
      window.removeEventListener("keydown", this.onKeyDown);
    }

    private onKeyDown = (event: KeyboardEvent) => {
      if (
        event.key.toLowerCase() !== "t" ||
        event.metaKey ||
        event.ctrlKey ||
        event.altKey ||
        this.isTyping(event.target)
      ) {
        return;
      }

      event.preventDefault();
      this.toggle();
    };

    private toggle = () => {
      if (ThemeSwitcher.transitionRunning) return;

      const current = this.currentTheme();
      const next = current === "dark" ? "light" : "dark";
      const reducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      ).matches;

      if (reducedMotion) {
        this.setTheme(next);
        return;
      }

      ThemeSwitcher.transitionRunning = true;
      window.dispatchEvent(new CustomEvent("theme-transition:start"));
      this.setControlsDisabled(true);
      this.button?.setAttribute("aria-busy", "true");

      const root =
        document.querySelector<HTMLElement>("keyboard-navigator") ??
        document.body;
      const clone = this.freezeClone(root.cloneNode(true) as HTMLElement, root);
      clone.querySelectorAll("[data-theme-label]").forEach((label) => {
        label.textContent = this.themeLabel(next);
      });
      const overlay = document.createElement("div");
      const overlayInner = document.createElement("div");

      overlay.className = `theme-reveal-overlay theme-preview-${next}`;
      overlay.setAttribute("aria-hidden", "true");
      overlay.style.animationDuration = `${REVEAL_DURATION_MS}ms`;
      this.pinStickyHeader(clone, overlay);
      overlayInner.style.transform = `translateY(-${window.scrollY}px)`;
      overlayInner.append(clone);
      overlay.append(overlayInner);
      document.body.append(overlay);

      const scrambleFragments = this.createScrambleFragments(clone, overlay);

      const sweep = document.createElement("div");
      sweep.className = "theme-sweep";
      sweep.setAttribute("aria-hidden", "true");
      sweep.style.animationDuration = `${REVEAL_DURATION_MS}ms`;
      document.body.append(sweep);

      let frame = 0;
      const startedAt = performance.now();
      const scramble = (now: number) => {
        const elapsed = now - startedAt;
        scrambleFragments.forEach((fragment) => {
          if (fragment.done || elapsed < fragment.startAt) return;

          if (elapsed >= fragment.endAt) {
            fragment.done = true;
            fragment.element.remove();
            return;
          }

          fragment.element.hidden = false;
          fragment.element.textContent = this.scrambleText(fragment.length);
        });
        frame = requestAnimationFrame(scramble);
      };

      frame = requestAnimationFrame(scramble);
      window.setTimeout(() => {
        cancelAnimationFrame(frame);
        scrambleFragments.forEach((fragment) => fragment.element.remove());
        this.commitTheme(next);
        overlay.remove();
        sweep.remove();
        ThemeSwitcher.transitionRunning = false;
        window.dispatchEvent(new CustomEvent("theme-transition:end"));
        this.setControlsDisabled(false);
        this.button?.removeAttribute("aria-busy");
        this.syncLabel();
      }, REVEAL_DURATION_MS + SCRAMBLE_DURATION_MS);
    };

    private currentTheme() {
      return document.documentElement.dataset.theme === "dark"
        ? "dark"
        : "light";
    }

    private setTheme(theme: "dark" | "light") {
      document.documentElement.classList.toggle("dark", theme === "dark");
      document.documentElement.dataset.theme = theme;
      localStorage.setItem(this.storageKey, theme);
      this.syncLabel();
    }

    private themeLabel(theme: "dark" | "light") {
      const key = theme === "dark" ? "darkLabel" : "lightLabel";
      return this.dataset[key] ?? theme;
    }

    private commitTheme(theme: "dark" | "light") {
      document.documentElement.classList.add("theme-commit");
      this.setTheme(theme);

      // Keep transition kill-switch active for two frames so the theme swap paints cleanly.
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          document.documentElement.classList.remove("theme-commit");
        });
      });
    }

    private syncLabel() {
      if (this.label)
        this.label.textContent = this.themeLabel(this.currentTheme());
    }

    private setControlsDisabled(disabled: boolean) {
      document
        .querySelectorAll<HTMLButtonElement>("[data-theme-toggle]")
        .forEach((button) => {
          button.disabled = disabled;
          button.setAttribute("aria-disabled", String(disabled));
        });
    }

    private freezeClone(root: HTMLElement, sourceRoot: HTMLElement) {
      const customSelectors = [
        "keyboard-navigator",
        "theme-switcher",
        "scramble-link",
        "experience-console",
        "skills-inventory",
      ].join(",");

      const replaceCustomElement = (element: HTMLElement) => {
        const replacement = document.createElement(
          element.tagName.toLowerCase() === "scramble-link" ||
            element.tagName.toLowerCase() === "theme-switcher"
            ? "span"
            : "div",
        );

        Array.from(element.attributes).forEach((attribute) => {
          if (attribute.name === "id") return;
          replacement.setAttribute(attribute.name, attribute.value);
        });

        replacement.replaceChildren(...Array.from(element.childNodes));
        element.replaceWith(replacement);
        return replacement;
      };

      let frozenRoot = root;
      if (root.matches(customSelectors)) {
        frozenRoot = replaceCustomElement(root);
      }

      Array.from(frozenRoot.querySelectorAll<HTMLElement>(customSelectors))
        .reverse()
        .forEach((element) => {
          replaceCustomElement(element);
        });

      frozenRoot
        .querySelectorAll<HTMLElement>(THEME_TRANSITION_STATIC_SELECTOR)
        .forEach((element, index) => {
          const source = sourceRoot.querySelectorAll<HTMLElement>(
            THEME_TRANSITION_STATIC_SELECTOR,
          )[index];
          const rect = source?.getBoundingClientRect();

          if (rect && rect.width > 0 && rect.height > 0) {
            element.style.inlineSize = `${rect.width}px`;
            element.style.blockSize = `${rect.height}px`;
          }

          element.style.animation = "none";
          element.style.transition = "none";
          element.style.transform = "none";
        });

      frozenRoot
        .querySelectorAll("script")
        .forEach((script) => script.remove());
      return frozenRoot;
    }

    private pinStickyHeader(root: HTMLElement, overlay: HTMLElement) {
      const header = root.querySelector<HTMLElement>("header");
      if (!header) return;

      const sourceHeader = document.querySelector<HTMLElement>("header");
      const rect = sourceHeader?.getBoundingClientRect();
      if (!rect || rect.height <= 0) return;

      const pinnedHeader = header.cloneNode(true) as HTMLElement;
      pinnedHeader.style.position = "fixed";
      pinnedHeader.style.insetBlockStart = "0";
      pinnedHeader.style.insetInlineStart = "0";
      pinnedHeader.style.insetInlineEnd = "0";
      pinnedHeader.style.zIndex = "2";

      const placeholder = document.createElement("div");
      placeholder.setAttribute("aria-hidden", "true");
      placeholder.style.blockSize = `${rect.height}px`;
      header.replaceWith(placeholder);
      overlay.append(pinnedHeader);
    }

    private createScrambleFragments(root: HTMLElement, overlay: HTMLElement) {
      const nodes = this.collectTextNodes(root, {
        includeAriaHidden: true,
      });
      const layer = document.createElement("div");
      layer.className = "theme-scramble-layer";
      overlay.append(layer);

      const fragments: Array<{
        element: HTMLElement;
        length: number;
        startAt: number;
        endAt: number;
        done: boolean;
      }> = [];

      nodes.forEach((node) => {
        const original = node.data;
        if (!original.trim()) return;

        const range = document.createRange();
        range.selectNodeContents(node);
        const rects = Array.from(range.getClientRects()).filter(
          (rect) => rect.width > 0 && rect.height > 0,
        );

        if (!rects.length) return;

        const parent = node.parentElement;
        if (!parent) return;

        const style = getComputedStyle(parent);
        rects.forEach((rect) => {
          const fragment = document.createElement("span");
          const fontSize = Number.parseFloat(style.fontSize) || 14;
          const estimatedCharacterWidth = Math.max(5, fontSize * 0.6);

          fragment.className = "theme-scramble-fragment";
          fragment.style.left = `${rect.left}px`;
          fragment.style.top = `${rect.top}px`;
          fragment.style.width = `${rect.width}px`;
          fragment.style.height = `${rect.height}px`;
          fragment.style.fontFamily = style.fontFamily;
          fragment.style.fontSize = style.fontSize;
          fragment.style.fontStyle = style.fontStyle;
          fragment.style.fontStretch = style.fontStretch;
          fragment.style.fontWeight = style.fontWeight;
          fragment.style.letterSpacing = style.letterSpacing;
          fragment.style.lineHeight = style.lineHeight;
          fragment.style.textTransform = style.textTransform;
          fragment.style.color = style.color;
          fragment.hidden = true;

          layer.append(fragment);
          const startAt = Math.min(
            REVEAL_DURATION_MS,
            Math.max(0, (rect.top / window.innerHeight) * REVEAL_DURATION_MS),
          );
          fragments.push({
            element: fragment,
            length: Math.max(
              1,
              Math.ceil(rect.width / estimatedCharacterWidth),
            ),
            startAt,
            endAt: startAt + SCRAMBLE_DURATION_MS,
            done: false,
          });
        });
      });

      return fragments;
    }

    private collectTextNodes(
      root: Node,
      options: { includeAriaHidden?: boolean } = {},
    ) {
      const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT, {
        acceptNode: (node) => {
          const parent = node.parentElement;
          if (!parent || !node.textContent?.trim()) {
            return NodeFilter.FILTER_REJECT;
          }

          const ignoredSelector = options.includeAriaHidden
            ? `${THEME_TRANSITION_BASE_IGNORED_SELECTOR}, ${THEME_TRANSITION_STATIC_SELECTOR}`
            : `${THEME_TRANSITION_BASE_IGNORED_SELECTOR}, ${THEME_TRANSITION_STATIC_SELECTOR}, [aria-hidden='true']`;

          if (parent.closest(ignoredSelector)) {
            return NodeFilter.FILTER_REJECT;
          }

          if (
            parent.closest("[data-theme-scramble-scope]") &&
            !parent.closest("[data-theme-scramble-target]")
          ) {
            return NodeFilter.FILTER_REJECT;
          }

          const style = getComputedStyle(parent);
          if (
            style.display === "none" ||
            style.visibility === "hidden" ||
            style.opacity === "0" ||
            parent.offsetParent === null
          ) {
            return NodeFilter.FILTER_REJECT;
          }

          return NodeFilter.FILTER_ACCEPT;
        },
      });

      const nodes: Text[] = [];
      while (walker.nextNode()) nodes.push(walker.currentNode as Text);
      return nodes;
    }

    private scrambleText(length: number) {
      return Array.from(
        { length },
        () => GLYPHS[(Math.random() * GLYPHS.length) | 0],
      ).join("");
    }

    private isTyping(target: EventTarget | null) {
      return (
        target instanceof HTMLElement &&
        (target.tagName === "INPUT" ||
          target.tagName === "TEXTAREA" ||
          target.tagName === "SELECT" ||
          target.isContentEditable)
      );
    }
  }

  if (!customElements.get("theme-switcher")) {
    customElements.define("theme-switcher", ThemeSwitcher);
  }
</script>
