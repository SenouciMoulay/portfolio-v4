---
import { localeFromPath } from "../../consts";

const { class: className, ...attrs } = Astro.props;
const locale = localeFromPath(Astro.url.pathname);
const copyLabel = locale === "en" ? "copy" : "copier";
const language =
  Astro.props["data-language"] ??
  (typeof className === "string"
    ? className.match(/language-([^\s]+)/)?.[1]
    : undefined) ??
  "text";
const label = `.${(language === "text" ? "sh" : language).toLowerCase()}`;
---

<code-copy-frame
  class="my-6 block overflow-hidden border border-border bg-background"
  data-theme-transition-static
  data-copy-idle={copyLabel}
  data-copy-done={locale === "en" ? "done" : "copié"}
  data-copy-fail={locale === "en" ? "fail" : "échec"}
>
  <div
    class="flex min-h-9 items-center gap-3 border-b border-border bg-muted px-3 py-2"
  >
    <span
      class="min-w-0 flex-1 truncate text-[0.7rem] tracking-[0.18em] text-muted-foreground"
      data-code-language
    >
      {label}
    </span>
    <button
      type="button"
      class="text-[0.7rem] tracking-[0.16em] text-muted-foreground underline decoration-border decoration-dotted underline-offset-4 hover:text-accent hover:decoration-accent focus-visible:text-accent focus-visible:decoration-accent focus-visible:outline-none"
      data-copy-code
      aria-label={`${copyLabel} ${label} code`}
    >
      {copyLabel}
    </button>
  </div>
  <pre
    {...attrs}
    class:list={[
      className,
      "!my-0 overflow-x-auto !border-0 !bg-transparent !px-0 !py-3 text-[0.8125rem] leading-relaxed",
    ]}
    data-copy-source><slot /></pre>
</code-copy-frame>
